          "event_type": {
            "const": "tinyfish.progress",
            "default": "tinyfish.progress",
            "title": "Event Type",
            "type": "string"
          },
          "job_id": {
            "title": "Job Id",
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/TinyFishProgressPayload"
          },
          "seq": {
            "title": "Seq",
            "type": "integer"
          }
        },
        "required": [
          "seq",
          "event_id",
          "job_id",
          "created_at",
          "payload"
        ],
        "title": "TinyFishProgressEvent",
        "type": "object"
      },
      "TinyFishProgressPayload": {
        "additionalProperties": false,
        "properties": {
          "purpose": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Purpose"
          },
          "trace": {
            "$ref": "#/components/schemas/TinyFishTraceEvent"
          },
          "url": {
            "title": "Url",
