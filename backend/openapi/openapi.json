            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "API for launching durable niche-discovery search jobs and streaming progress over SSE.",
    "title": "NotNemo Search API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/search": {
      "post": {
        "operationId": "create_search_job_api_search_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchAcceptedResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Restate ingress is unavailable or rejected the workflow submission."
          }
        },
        "summary": "Create Search Job",
        "tags": [
          "search"
        ]
      }
    },
    "/api/search/{job_id}": {
      "get": {
        "operationId": "get_search_job_api_search__job_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "title": "Job Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchSnapshotResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Not Found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Bad Gateway"
          }
        },
        "summary": "Get Search Job",
        "tags": [
          "search"
        ]
      }
    },
    "/api/search/{job_id}/events": {
      "get": {
        "operationId": "stream_search_events_api_search__job_id__events_get",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "title": "Job Id",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "since",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Since"
            }
          },
          {
            "in": "header",
            "name": "Last-Event-ID",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Last-Event-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "examples": {
                  "job.started": {
                    "summary": "Search job started",
                    "value": "event: job.started\ndata: {\"event_type\":\"job.started\"}\n\n"
                  },
                  "result.item": {
                    "summary": "Result item",
                    "value": "event: result.item\ndata: {\"event_type\":\"result.item\",\"payload\":{\"result\":{\"url\":\"https://example.com\"}}}\n\n"
                  },
                  "tinyfish.progress": {
                    "summary": "TinyFish progress",
                    "value": "event: tinyfish.progress\ndata: {\"event_type\":\"tinyfish.progress\",\"payload\":{\"url\":\"https://example.com\",\"purpose\":\"Extracting products\"}}\n\n"
                  }
                },
                "schema": {
                  "format": "event-stream",
                  "type": "string"
                }
              }
            },
            "description": "Server-Sent Events stream. Each `data:` line contains a JSON SearchEvent envelope.",
            "x-event-models": [
              {
                "$ref": "#/components/schemas/JobStartedEvent"
              },
              {
                "$ref": "#/components/schemas/SeedsReadyEvent"
              },
              {
                "$ref": "#/components/schemas/DomainsReadyEvent"
              },
              {
                "$ref": "#/components/schemas/BranchStartedEvent"
              },
              {
                "$ref": "#/components/schemas/TinyFishProgressEvent"
              },
              {
                "$ref": "#/components/schemas/ResultItemEvent"
              },
              {
                "$ref": "#/components/schemas/BranchCompletedEvent"
              },
              {
                "$ref": "#/components/schemas/JobCompletedEvent"
              },
              {
                "$ref": "#/components/schemas/JobFailedEvent"
              },
              {
                "$ref": "#/components/schemas/KeepAliveEvent"
              }
            ]
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Not Found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Bad Gateway"
          }
        },
        "summary": "Stream Search Events",
        "tags": [
          "search"
        ]
      }
    },
    "/db": {
      "get": {
        "operationId": "db_check_db_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "integer"
                      }
                    ]
                  },
                  "title": "Response Db Check Db Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Db Check",
        "tags": [
          "meta"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "meta"
        ]
      }
    }
  }
}
